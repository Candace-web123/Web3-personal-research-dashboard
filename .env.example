# Web3 Research Dashboard — 环境变量
# 复制此文件为 .env.local 并填入实际值

# CoinGlass Open API v2（可选）
# 未设置时，资金费率和 OI 变化率字段自动回退 demo 数据，页面正常运行。
# 注册地址：https://www.coinglass.com/zh/api
COINGLASS_API_KEY=

# Anthropic API（可选，仅日报 AI 生成需要）
# 未设置时，npm run report 将报错退出；npm run report:dry 无需此变量。
# 注册地址：https://console.anthropic.com/
ANTHROPIC_API_KEY=
